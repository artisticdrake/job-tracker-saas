{
  "manifest_version": 3,
  "name": "JobTracker Linker",
  "version": "1.1",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:3001/*"],
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/jobs/view/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}